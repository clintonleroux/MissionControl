@rendermode InteractiveServer
@inject IProviderBridgeRegistry BridgeRegistry
@inject IDbContextFactory<MissionControlDb> DbFactory
@implements IDisposable

<div class="bridge-status @(_online ? "ok" : "bad")">
    <span class="dot"></span>
    <span>Providers: @(_onlineCount)/@(_totalProviders) online</span>
</div>

@code {
    private bool _online;
    private int _onlineCount;
    private int _totalProviders;
    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        _timer = new System.Threading.Timer(async _ =>
        {
            await CheckProvidersAsync();
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(5));
    }

    private async Task CheckProvidersAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var providers = await db.Providers.Include(p => p.Models).Where(p => p.IsEnabled).ToListAsync();
            _totalProviders = providers.Count;
            _onlineCount = 0;
            foreach (var provider in providers)
            {
                if (BridgeRegistry.IsProviderAvailable(provider))
                    _onlineCount++;
            }
            _online = _onlineCount > 0;
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    public void Dispose() => _timer?.Dispose();
}