@page "/runs/{RunId:int}"
@rendermode InteractiveServer
@inject IDbContextFactory<MissionControlDb> DbFactory
@implements IDisposable

<PageTitle>Run @RunId · Mission Control</PageTitle>

@if (_run is null)
{
    <h1>Run @RunId</h1>
    <p class="muted">Loading…</p>
}
else
{
    <h1>Run #@_run.Id — @_run.AgentTask?.Name</h1>

    <div class="meta-grid">
        <div><strong>Status:</strong> <span class="status @_run.Status.ToString().ToLower()">@_run.Status</span></div>
        <div><strong>Started:</strong> @_run.StartedAt.ToLocalTime().ToString("O")</div>
        <div><strong>Completed:</strong> @(_run.CompletedAt?.ToLocalTime().ToString("O") ?? "—")</div>
        <div><strong>Bridge run id:</strong> <code>@(_run.BridgeRunId ?? "—")</code></div>
        <div><strong>Vault note:</strong> <code>@(_run.VaultNotePath ?? "—")</code></div>
    </div>

    <section>
        <h2>Prompt</h2>
        <pre class="code">@_run.AgentTask?.Prompt</pre>
    </section>

    @if (!string.IsNullOrWhiteSpace(_run.Result))
    {
        <section>
            <h2>Result</h2>
            <pre class="code">@_run.Result</pre>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(_run.ErrorMessage))
    {
        <section>
            <h2>Error</h2>
            <pre class="code error">@_run.ErrorMessage</pre>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(_run.Transcript))
    {
        <section>
            <h2>Transcript</h2>
            <pre class="code scroll">@_run.Transcript</pre>
        </section>
    }
}

@code {
    [Parameter] public int RunId { get; set; }

    private AgentRun? _run;
    private System.Threading.Timer? _timer;

    protected override async Task OnParametersSetAsync()
    {
        await ReloadAsync();
        _timer?.Dispose();
        _timer = new System.Threading.Timer(async _ =>
        {
            await ReloadAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private async Task ReloadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _run = await db.AgentRuns.Include(r => r.AgentTask).FirstOrDefaultAsync(r => r.Id == RunId);
    }

    public void Dispose() => _timer?.Dispose();
}
