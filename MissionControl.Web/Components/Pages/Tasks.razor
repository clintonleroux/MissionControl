@page "/tasks"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using MissionControl.Models
@using MissionControl.Models.Enums
@inject IDbContextFactory<MissionControlDb> DbFactory
@inject AgentRunner Runner
@inject NavigationManager Nav

<PageTitle>Tasks · Mission Control</PageTitle>

<h1>Tasks</h1>

<div class="row gap" style="margin-bottom: 1rem">
    <select class="input" @bind="_filterProjectId" @bind:after="OnFilterChanged">
        <option value="0">All projects</option>
        @foreach (var p in _projects)
        {
            <option value="@p.Id">@p.Name</option>
        }
    </select>
    <select class="input" @bind="_filterStatus" @bind:after="OnFilterChanged">
        <option value="">All statuses</option>
        <option value="Pending">Pending</option>
        <option value="Running">Running</option>
        <option value="Completed">Completed</option>
        <option value="Failed">Failed</option>
    </select>
    <button class="btn primary" @onclick="() => { _showCreate = !_showCreate; _editing = null; }">
        @(_showCreate ? "Cancel" : "+ New task")
    </button>
</div>

@if (_showCreate)
{
    <div class="card">
        <h3>New task</h3>
        <EditForm Model="_new" OnValidSubmit="CreateAsync">
            <TaskFields _model="_new" _models="_models" />
            <button type="submit" class="btn primary">Create</button>
        </EditForm>
    </div>
}

@if (_tasks.Count == 0)
{
    <p class="muted">No tasks defined yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>#</th>
                <th>Stage</th>
                <th>Name</th>
                <th>Status</th>
                <th>Model</th>
                <th>Prompt</th>
                <th>Tools</th>
                <th>Turns</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in _tasks)
            {
                @if (_editing?.Id == t.Id)
                {
                    <tr>
                        <td colspan="10">
                            <EditForm Model="_editing" OnValidSubmit="() => SaveAsync()">
                                <h4>Edit task #@t.Id</h4>
                                <TaskFields _model="_editing" _models="_models" />
                                <button type="submit" class="btn primary">Save</button>
                                <button type="button" class="btn" @onclick="() => _editing = null">Cancel</button>
                            </EditForm>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td>@t.Id</td>
                        <td><span class="badge">@t.Stage</span></td>
                        <td><strong>@t.Name</strong></td>
                        <td><span class="badge">@t.Status</span></td>
                        <td>@(t.Model?.Provider?.Name ?? "?")/@(t.Model?.Name ?? "—")</td>
                        <td class="truncate">@t.Prompt</td>
                        <td>@(t.AllowedTools ?? "—")</td>
                        <td>@t.MaxTurns</td>
                        <td class="row gap-sm">
                            @if (t.Status != MissionControl.Models.Enums.TaskStatus.Completed && t.Status != MissionControl.Models.Enums.TaskStatus.Running)
                            {
                                <button class="btn" @onclick="() => RunAsync(t.Id)">Run</button>
                            }
                            else if (t.Status == MissionControl.Models.Enums.TaskStatus.Running)
                            {
                                <span class="badge">Running...</span>
                            }
                            <button class="btn" @onclick="() => ViewTask(t.Id)">View</button>
                            <button class="btn" @onclick="() => EditTask(t)">Edit</button>
                            <button class="btn danger" @onclick="() => DeleteAsync(t.Id)">Delete</button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private List<AgentTask> _tasks = new();
    private List<Model> _models = new();
    private List<Project> _projects = new();
    [SupplyParameterFromQuery] private int ProjectId { get; set; }
    private int _filterProjectId;
    private string _filterStatus = "";
    private bool _showCreate;
    private AgentTask _new = Blank();
    private AgentTask? _editing;

    protected override async Task OnInitializedAsync()
    {
        _filterProjectId = ProjectId;
        await LoadAsync();
    }

    private async Task OnFilterChanged() => await LoadAsync();

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _projects = await db.Projects.Where(p => p.IsActive).OrderBy(p => p.Name).ToListAsync();
        var query = db.AgentTasks
            .Include(t => t.Model).ThenInclude(m => m!.Provider)
            .Include(t => t.Project)
            .Where(t => _filterProjectId == 0 || t.ProjectId == _filterProjectId)
            .AsQueryable();

        if (!string.IsNullOrEmpty(_filterStatus))
        {
            var status = Enum.Parse<MissionControl.Models.Enums.TaskStatus>(_filterStatus);
            query = query.Where(t => t.Status == status);
        }

        _tasks = await query.OrderByDescending(t => t.Priority).ThenBy(t => t.Id).ToListAsync();
        _models = await db.Models
            .Include(m => m.Provider)
            .Where(m => m.IsEnabled)
            .OrderBy(m => m.Provider!.Name).ThenBy(m => m.Name)
            .ToListAsync();
    }

    private void EditTask(AgentTask t)
    {
        _showCreate = false;
        _editing = new AgentTask
        {
            Id = t.Id,
            Name = t.Name,
            Prompt = t.Prompt,
            Stage = t.Stage,
            ModelId = t.ModelId,
            AllowedTools = t.AllowedTools,
            MaxTurns = t.MaxTurns,
            Priority = t.Priority
        };
    }

    private async Task SaveAsync()
    {
        if (_editing is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var t = await db.AgentTasks.FindAsync(_editing.Id);
        if (t is not null)
        {
            t.Name = _editing.Name;
            t.Prompt = _editing.Prompt;
            t.Stage = _editing.Stage;
            t.ModelId = _editing.ModelId;
            t.AllowedTools = _editing.AllowedTools;
            t.MaxTurns = _editing.MaxTurns;
            t.Priority = _editing.Priority;
            await db.SaveChangesAsync();
        }
        _editing = null;
        await LoadAsync();
    }

    private async Task CreateAsync()
    {
        if (_new.ModelId > 0)
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var model = await ctx.Models.Include(m => m.Provider).FirstOrDefaultAsync(m => m.Id == _new.ModelId);
            _new.ModelId = model?.Id ?? 0;
        }
        _new.ProjectId = _filterProjectId > 0 ? _filterProjectId : _projects.FirstOrDefault()?.Id ?? 0;
        await using var db = await DbFactory.CreateDbContextAsync();
        db.AgentTasks.Add(_new);
        await db.SaveChangesAsync();
        _new = Blank();
        _showCreate = false;
        await LoadAsync();
    }

    private async Task RunAsync(int taskId)
    {
        var runId = await Runner.StartAsync(taskId);
        Nav.NavigateTo($"runs/{runId}");
    }

    private async Task ViewTask(int taskId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var runs = await db.AgentRuns
            .Where(r => r.AgentTaskId == taskId)
            .OrderByDescending(r => r.StartedAt)
            .Take(1)
            .ToListAsync();
        if (runs.Count > 0)
            Nav.NavigateTo($"/runs/{runs.First().Id}");
        else
            Nav.NavigateTo("/tasks");
    }

    private async Task DeleteAsync(int taskId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var t = await db.AgentTasks.FindAsync(taskId);
        if (t is not null) { db.AgentTasks.Remove(t); await db.SaveChangesAsync(); }
        await LoadAsync();
    }

    private static AgentTask Blank() => new()
    {
        Name = "",
        Prompt = "",
        AllowedTools = "Read,Write,Grep,Glob",
        MaxTurns = 10
    };
}