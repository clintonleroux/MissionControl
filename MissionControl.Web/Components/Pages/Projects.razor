@page "/projects"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using MissionControl.Models
@inject IDbContextFactory<MissionControlDb> DbFactory
@inject NavigationManager Nav

<PageTitle>Projects · Mission Control</PageTitle>

<h1>Projects</h1>

<div class="row gap">
    <button class="btn primary" @onclick="() => _showCreate = !_showCreate">
        @(_showCreate ? "Cancel" : "+ New project")
    </button>
</div>

@if (_showCreate)
{
    <div class="card">
        <h3>New project</h3>
        <EditForm Model="_newProject" OnValidSubmit="CreateProjectAsync">
            <div class="form-row">
                <label>Name</label>
                <InputText @bind-Value="_newProject.Name" class="input" />
            </div>
            <div class="form-row">
                <label>Description</label>
                <InputText @bind-Value="_newProject.Description" class="input" />
            </div>
            <div class="form-row">
                <label>Folder path</label>
                <InputText @bind-Value="_newProject.FolderPath" class="input" placeholder="C:\Projects\MyProject" />
            </div>
            <button type="submit" class="btn primary">Create</button>
        </EditForm>
    </div>
}

@if (_projects.Count == 0)
{
    <p class="muted">No projects yet. Create one to get started.</p>
}
else
{
    @foreach (var p in _projects)
    {
        var projectId = p.Id;
        var isExpanded = _expandedProjects.Contains(projectId);

        <div class="card">
            <div class="row-between">
                <div>
                    @if (_editingProject?.Id == p.Id)
                    {
                        <div class="form-row">
                            <label>Name</label>
                            <InputText @bind-Value="_editingProject.Name" class="input" />
                        </div>
                        <div class="form-row">
                            <label>Description</label>
                            <InputText @bind-Value="_editingProject.Description" class="input" />
                        </div>
                        <div class="form-row">
                            <label>Folder path</label>
                            <InputText @bind-Value="_editingProject.FolderPath" class="input" />
                        </div>
                        <div class="form-row">
                            <label>
                                <input type="checkbox" @bind="_editingProject.IsActive" /> Active
                            </label>
                        </div>
                    }
                    else
                    {
                        <h3>@p.Name</h3>
                        <span class="muted">@if (!string.IsNullOrEmpty(p.Description)) { @p.Description } else { <span>No description</span> }</span>
                        <span class="muted">@if (!string.IsNullOrEmpty(p.FolderPath)) { <code>@p.FolderPath</code> } else { <span>No folder</span> }</span>
                    }
                </div>
                <div class="row gap">
                    <button class="btn small" @onclick="() => ViewTasks(projectId)">View</button>
                    <button class="btn small" @onclick="() => ToggleTasks(projectId)">
                        @(isExpanded ? "Hide Tasks" : "Show Tasks") (@p.Tasks.Count)
                    </button>
                    @if (_editingProject?.Id == p.Id)
                    {
                        <button class="btn" @onclick="SaveEditAsync">Save</button>
                        <button class="btn" @onclick="() => _editingProject = null">Cancel</button>
                    }
                    else
                    {
                        <button class="btn small" @onclick="() => _editingProject = p">Edit</button>
                        <button class="btn small" @onclick="() => DeleteProjectAsync(p.Id)">Delete</button>
                    }
                </div>
            </div>

            @if (isExpanded)
            {
                <div class="section">
                    <div class="row gap">
                        <button class="btn small primary" @onclick="() => ShowAddTask(projectId)">+ Add Task</button>
                    </div>

                    @if (_addingTaskProjectId == projectId)
                    {
                        <div class="card">
                            <h4>New Task</h4>
                            <EditForm Model="_newTask" OnValidSubmit="CreateTaskAsync">
                                <div class="form-row">
                                    <label>Name</label>
                                    <InputText @bind-Value="_newTask.Name" class="input" />
                                </div>
                                <div class="form-row">
                                    <label>Prompt</label>
                                    <InputTextArea @bind-Value="_newTask.Prompt" class="input" rows="3" />
                                </div>
                                <div class="form-row">
                                    <label>System prompt</label>
                                    <InputText @bind-Value="_newTask.SystemPrompt" class="input" />
                                </div>
                                <div class="form-row">
                                    <label>Max turns</label>
                                    <InputNumber @bind-Value="_newTask.MaxTurns" class="input" />
                                </div>
                                <button type="submit" class="btn primary">Create</button>
                                <button type="button" class="btn" @onclick="() => _addingTaskProjectId = null">Cancel</button>
                            </EditForm>
                        </div>
                    }

                    @if (p.Tasks.Count == 0)
                    {
                        <p class="muted">No tasks yet.</p>
                    }
                    else
                    {
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Prompt</th>
                                    <th>Max Turns</th>
                                    <th>Runs</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in p.Tasks)
                                {
                                    <tr>
                                        <td>
                                            @if (_editingTask?.Id == t.Id)
                                            {
                                                <InputText @bind-Value="_editingTask.Name" class="input" />
                                            }
                                            else
                                            {
                                                <strong>@t.Name</strong>
                                            }
                                        </td>
                                        <td>
                                            @if (_editingTask?.Id == t.Id)
                                            {
                                                <InputTextArea @bind-Value="_editingTask.Prompt" class="input" rows="2" />
                                            }
                                            else
                                            {
                                                <span class="muted">@t.Prompt</span>
                                            }
                                        </td>
                                        <td>@t.MaxTurns</td>
                                        <td>@t.Runs.Count</td>
                                        <td>
                                            @if (_editingTask?.Id == t.Id)
                                            {
                                                <button class="btn small" @onclick="SaveTaskEditAsync">Save</button>
                                                <button class="btn small" @onclick="() => _editingTask = null">Cancel</button>
                                            }
                                            else
                                            {
                                                <button class="btn small" @onclick="() => _editingTask = t">Edit</button>
                                                <button class="btn small" @onclick="() => DeleteTaskAsync(t.Id)">Delete</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }
        </div>
    }
}

@code {
    private List<Project> _projects = new();
    private Project _newProject = new();
    private Project? _editingProject;
    private bool _showCreate;

    private HashSet<int> _expandedProjects = new();
    private int? _addingTaskProjectId;
    private AgentTask _newTask = new();
    private AgentTask? _editingTask;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _projects = await db.Projects.Include(p => p.Tasks).ThenInclude(t => t.Runs).ToListAsync();
    }

    private async Task CreateProjectAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.Projects.Add(_newProject);
        await db.SaveChangesAsync();
        _newProject = new();
        _showCreate = false;
        await LoadAsync();
    }

    private async Task SaveEditAsync()
    {
        if (_editingProject is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var p = await db.Projects.FindAsync(_editingProject.Id);
        if (p is not null)
        {
            p.Name = _editingProject.Name;
            p.Description = _editingProject.Description;
            p.FolderPath = _editingProject.FolderPath;
            p.IsActive = _editingProject.IsActive;
            await db.SaveChangesAsync();
        }
        _editingProject = null;
        await LoadAsync();
    }

    private async Task DeleteProjectAsync(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var p = await db.Projects.FindAsync(id);
        if (p is not null) { db.Projects.Remove(p); await db.SaveChangesAsync(); }
        await LoadAsync();
    }

    private void ViewTasks(int projectId)
    {
        Nav.NavigateTo($"/tasks?projectId={projectId}");
    }

    private void ToggleTasks(int projectId)
    {
        if (_expandedProjects.Contains(projectId))
            _expandedProjects.Remove(projectId);
        else
            _expandedProjects.Add(projectId);
    }

    private void ShowAddTask(int projectId)
    {
        _addingTaskProjectId = projectId;
        _newTask = new() { ProjectId = projectId, MaxTurns = 10 };
    }

    private async Task CreateTaskAsync()
    {
        if (_addingTaskProjectId is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        db.AgentTasks.Add(_newTask);
        await db.SaveChangesAsync();
        _newTask = new();
        _addingTaskProjectId = null;
        await LoadAsync();
    }

    private async Task SaveTaskEditAsync()
    {
        if (_editingTask is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var t = await db.AgentTasks.FindAsync(_editingTask.Id);
        if (t is not null)
        {
            t.Name = _editingTask.Name;
            t.Prompt = _editingTask.Prompt;
            t.SystemPrompt = _editingTask.SystemPrompt;
            t.MaxTurns = _editingTask.MaxTurns;
            await db.SaveChangesAsync();
        }
        _editingTask = null;
        await LoadAsync();
    }

    private async Task DeleteTaskAsync(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var t = await db.AgentTasks.FindAsync(id);
        if (t is not null) { db.AgentTasks.Remove(t); await db.SaveChangesAsync(); }
        await LoadAsync();
    }
}