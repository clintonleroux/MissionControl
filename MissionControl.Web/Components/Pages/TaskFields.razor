@using MissionControl.Models

<div class="form-row">
    <label>Name</label>
    <InputText @bind-Value="_model.Name" class="input" />
</div>
<div class="form-row">
    <label>Prompt</label>
    <InputTextArea @bind-Value="_model.Prompt" class="input" rows="4" />
</div>
<div class="form-row">
    <label>System prompt (optional)</label>
    <InputTextArea @bind-Value="_model.SystemPrompt" class="input" rows="2" />
</div>
<div class="form-row">
    <label>Model</label>
    <InputSelect @bind-Value="_model.ModelId" class="input">
        <option value="">Use provider default</option>
        @foreach (var m in _models)
        {
            <option value="@m.Id">@(m.Provider?.Name ?? "?") / @m.Name</option>
        }
    </InputSelect>
</div>
<div class="form-row">
    <label>Allowed tools (comma-separated)</label>
    <InputText @bind-Value="_model.AllowedTools" class="input" placeholder="Read,Write,Grep,Glob,Edit" />
</div>
<div class="form-row">
    <label>Max turns</label>
    <InputNumber @bind-Value="_model.MaxTurns" class="input short" />
</div>

@code {
    [Parameter, EditorRequired] public AgentTask _model { get; set; } = default!;
    [Parameter, EditorRequired] public List<Model> _models { get; set; } = default!;
}