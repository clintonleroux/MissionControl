@using MissionControl.Models
@using MissionControl.Models.Enums

<div class="form-row">
    <label>Name</label>
    <InputText @bind-Value="_model.Name" class="input" />
</div>
<div class="form-row">
    <label>Stage</label>
    <InputSelect @bind-Value="_model.Stage" class="input">
        @foreach (TaskStage stage in Enum.GetValues<TaskStage>())
        {
            <option value="@stage">@stage</option>
        }
    </InputSelect>
</div>
<div class="form-row">
    <label>Prompt</label>
    <InputTextArea @bind-Value="_model.Prompt" class="input" rows="4" />
</div>
<div class="form-row">
    <label>Model (optional)</label>
    <InputSelect @bind-Value="_model.ModelId" class="input">
        <option value="">Default</option>
        @foreach (var m in _models)
        {
            <option value="@m.Id">@(m.Provider?.Name ?? "?") / @m.Name</option>
        }
    </InputSelect>
</div>
<div class="form-row">
    <label>Allowed tools (comma-separated)</label>
    <InputText @bind-Value="_model.AllowedTools" class="input" placeholder="Read,Write,Grep,Glob,Edit" />
</div>
<div class="form-row">
    <label>Max turns</label>
    <InputNumber @bind-Value="_model.MaxTurns" class="input short" />
</div>
<div class="form-row">
    <label>Priority</label>
    <InputSelect @bind-Value="_model.Priority" class="input">
        <option value="0">Low</option>
        <option value="1">Normal</option>
        <option value="2">High</option>
        <option value="3">Urgent</option>
    </InputSelect>
</div>

@code {
    [Parameter, EditorRequired] public AgentTask _model { get; set; } = default!;
    [Parameter, EditorRequired] public List<Model> _models { get; set; } = default!;
}